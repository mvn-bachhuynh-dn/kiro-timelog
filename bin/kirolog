#!/usr/bin/env node
import { join, dirname } from 'node:path';
import { fileURLToPath } from 'node:url';
import { execFileSync } from 'node:child_process';
import { readFileSync } from 'node:fs';

const __dirname = dirname(fileURLToPath(import.meta.url));
const scriptsDir = join(__dirname, '..', 'scripts');
const args = process.argv.slice(2);

// Handle scheduler commands
if (args[0] === 'install-scheduler') {
  execFileSync(process.execPath, [join(scriptsDir, 'scheduler.mjs'), 'install'], { stdio: 'inherit' });
  process.exit(0);
}
if (args[0] === 'uninstall-scheduler') {
  execFileSync(process.execPath, [join(scriptsDir, 'scheduler.mjs'), 'uninstall'], { stdio: 'inherit' });
  process.exit(0);
}
if (args.includes('--version') || args.includes('-v')) {
  const pkg = JSON.parse(readFileSync(join(__dirname, '..', 'package.json'), 'utf8'));
  console.log(`ailog v${pkg.version}`);
  process.exit(0);
}
if (args.includes('--update')) {
  console.log('Checking for updates...');
  try {
    const latest = execFileSync('npm', ['view', '@steveh204/ailog', 'version'], { encoding: 'utf8' }).trim();
    const pkg = JSON.parse(readFileSync(join(__dirname, '..', 'package.json'), 'utf8'));
    if (latest === pkg.version) {
      console.log(`Already up to date (v${pkg.version})`);
    } else {
      console.log(`Updating v${pkg.version} → v${latest}...`);
      execFileSync('npm', ['install', '-g', `@steveh204/ailog@${latest}`], { stdio: 'inherit' });
      console.log(`✓ Updated to v${latest}`);
    }
  } catch (e) {
    console.error('Update failed:', e.message || 'Check your network connection');
    process.exit(1);
  }
  process.exit(0);
}

// Scan first (silent)
try {
  execFileSync(process.execPath, [join(scriptsDir, 'scan.mjs')], { stdio: 'ignore', timeout: 30000 });
} catch {}

// Run report
const reportArgs = [join(scriptsDir, 'report.mjs'), ...args];
try {
  const out = execFileSync(process.execPath, reportArgs, { encoding: 'utf8', stdio: ['pipe', 'pipe', 'pipe'] });
  if (out) process.stdout.write(out);
} catch (e) {
  if (e.stdout) process.stdout.write(e.stdout);
  if (e.stderr) process.stderr.write(e.stderr);
  process.exit(e.status || 1);
}
